# ==============================================================================
# 🛡️ Life Vault Frontend Environment Variables
# ==============================================================================
# This file contains the environment variables used by the Vite frontend.
# Since these are prefixed with "VITE_", they will be exposed to the browser.
# DO NOT ADD PRIVATE SECRETS (like private keys or secret tokens) HERE.
# ==============================================================================

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------
# The base URL of the Life Vault backend API.
# For local development: http://127.0.0.1:5000/api
# For production: https://your-server-domain.com/api
VITE_API_URL=http://127.0.0.1:5000/api

# ------------------------------------------------------------------------------
# IPFS & Storage Configuration
# ------------------------------------------------------------------------------
# The gateway URL used to fetch files and images stored securely via IPFS.
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ------------------------------------------------------------------------------
# Web3 & Blockchain Configuration
# ------------------------------------------------------------------------------
# The Aptos network to use ('mainnet', 'testnet', or 'devnet')
VITE_APTOS_NETWORK=testnet

# The Bitcoin network to use ('mainnet', 'testnet3', 'testnet4', or 'signet')
VITE_BITCOIN_NETWORK=testnet4
